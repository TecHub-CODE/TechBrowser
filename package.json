{
  "name": "techbrowser02",
  "version": "2.1.0",
  "description": "TechBrowser02 - Modern Masaüstü Tarayıcı",
  "main": "main.js",
  "author": "TechBrowser Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "electron-updater": "^6.8.3",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.techbrowser.app",
    "productName": "TechBrowser02",
    "publish": {
      "provider": "github",
      "owner": "TecHub-CODE",
      "repo": "TechBrowser"
    },
    "files": [
      "**/*",
      "!.git",
      "!.gitignore",
      "!techbrowser-users.json",
      "!techbrowser-data.json",
      "!techbrowser-otp.json",
      "!dist/**",
      "!*.md",
      "!.env"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TechBrowser02",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerLanguages": [
        "tr_TR",
        "en_US"
      ],
      "language": "1055"
    }
  }
}
